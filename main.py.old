async def wizard_router(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Routes incoming /start commands to the right PM Wizard, or to the normal start logic."""
    payload = context.args[0] if context.args else ""
    
    if payload.startswith("addopt_"):
        trip_id = payload.split("_")[1]
        context.user_data["wiz_trip_id"] = trip_id
        
        # Fetch trip title for flavor
        trip_query = supabase.table("trips").select("title").eq("id", trip_id).single().execute()
        title = trip_query.data["title"]
        
        # Quick category keyboard
        reply_markup = ReplyKeyboardMarkup([
            ["Accommodation", "Flights"],
            ["Activities", "Food"]
        ], one_time_keyboard=True, resize_keyboard=True)
        
        await update.message.reply_text(
            f"Let's add an option for **{title}**!\n\nFirst, what category is this? (Tap a button or type your own)",
            reply_markup=reply_markup
        )
        return ADD_OPT_CAT
    
    if payload.startswith("paid_"):
        trip_id = payload.split("_")[1]
        context.user_data["wiz_trip_id"] = trip_id
        await update.message.reply_text("💸 Let's log an expense! \n\nHow much did you pay? (e.g., 150.50)")
        return PAID_AMOUNT
        
    if payload.startswith("lock_"):
        trip_id = payload.split("_")[1]
        context.user_data["wiz_trip_id"] = trip_id
        
        reply_markup = ReplyKeyboardMarkup([
            ["Accommodation", "Flight"],
            ["Activity", "Food"],
            ["Transport", "Other"]
        ], one_time_keyboard=True, resize_keyboard=True)
        
        await update.message.reply_text(
            "🔒 Let's lock in an itinerary item!\n\nFirst, what category is this?", 
            reply_markup=reply_markup
        )
        return LOCK_CAT
        
    # If it's a normal start or a group invite, pass it to your original start function
    await start(update, context)
    return ConversationHandler.END

async def wiz_addopt_cat(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["wiz_cat"] = update.message.text.lower()
    await update.message.reply_text(
        "Got it. Now, what's the name or title of this option?\n(e.g., 'The Beach House')", 
        reply_markup=ReplyKeyboardRemove()
    )
    return ADD_OPT_NAME

async def wiz_addopt_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["wiz_name"] = update.message.text
    await update.message.reply_text(
        "Almost done. What are the specific dates for this?\n"
        "Example: `15 June to 18 June 2026`\n\n"
        "*(If dates don't matter for this, just type 'skip')*"
    )
    return ADD_OPT_DATES


async def wiz_addopt_dates(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_input = update.message.text.strip().lower()
    trip_id = context.user_data["wiz_trip_id"]
    
    # Fetch trip boundaries for the smart parser
    trip_query = supabase.table("trips").select("start_date, end_date").eq("id", trip_id).single().execute()
    t_start = trip_query.data["start_date"]
    t_end = trip_query.data["end_date"]
    
    start_date, end_date = None, None
    if user_input != 'skip':
        start_date, end_date = smart_parse_dates(user_input, t_start, t_end)
        if not start_date or not end_date:
            await update.message.reply_text("❌ I couldn't understand those dates.\nTry just the days (e.g., `15-18`), or `Day 1 to Day 3`, or type 'skip'.")
            return ADD_OPT_DATES
            
    # Time to save!
    trip_id = context.user_data["wiz_trip_id"]
    cat = context.user_data["wiz_cat"]
    name = context.user_data["wiz_name"]
    user_id = update.effective_user.id
    
    # Get DB user ID
    user_query = supabase.table("users").select("id").eq("telegram_id", user_id).single().execute()
    db_user_id = user_query.data["id"]
    
    # Save to Supabase
    supabase.table("poll_options").insert({
        "trip_id": trip_id,
        "category": cat,
        "option_text": name,
        "start_date": start_date.isoformat() if start_date else None,
        "end_date": end_date.isoformat() if end_date else None,
        "added_by": db_user_id
    }).execute()
    
    await update.message.reply_text("✅ Awesome, it's saved! I'll let the group know.")
    
    # Announce back to the group chat!
    trip_query = supabase.table("trips").select("group_chat_id").eq("id", trip_id).execute()
    if trip_query.data and trip_query.data[0]["group_chat_id"]:
        group_chat_id = trip_query.data[0]["group_chat_id"]
        first_name = update.effective_user.first_name
        date_str = f" ({start_date.strftime('%b %d')} - {end_date.strftime('%b %d')})" if start_date else ""
        
        # Base announcement
        announcement = f"💡 **New Idea!**\n{first_name} just added **{name}** to the {cat} options{date_str}!"
        
        # THE MILESTONE CHECK: Is this the very first option for this trip?
        options_query = supabase.table("poll_options").select("id").eq("trip_id", trip_id).execute()
        if len(options_query.data) == 1:
            announcement += (
                "\n\n🎓 **Pro Tip:** This is our first pitched idea! "
                "Keep adding options. Once we have a few good ones, anyone can type `/vote accommodation` "
                "(or whatever category) to generate a poll so the group can decide!"
            )
            
        await context.bot.send_message(chat_id=group_chat_id, text=announcement)
    
    return ConversationHandler.END
    
async def wiz_paid_amount(update: Update, context: ContextTypes.DEFAULT_TYPE):
    # Clean the input (remove $ if they typed it)
    amount_text = update.message.text.replace('$', '').strip()
    try:
        amount = float(amount_text)
        if amount <= 0: raise ValueError
    except ValueError:
        await update.message.reply_text("❌ Please enter a valid number greater than 0 (e.g., 45.50).")
        return PAID_AMOUNT
        
    context.user_data["wiz_amount"] = amount
    await update.message.reply_text("Great. What was this for? (e.g., 'Uber to the airport', 'Dinner at Marios')")
    return PAID_DESC

async def wiz_paid_desc(update: Update, context: ContextTypes.DEFAULT_TYPE):
    desc = update.message.text.strip()
    trip_id = context.user_data["wiz_trip_id"]
    amount = context.user_data["wiz_amount"]
    user_id = update.effective_user.id
    
    # DB Magic
    user_query = supabase.table("users").select("id").eq("telegram_id", user_id).single().execute()
    db_user_id = user_query.data["id"]
    
    supabase.table("expenses").insert({
        "trip_id": trip_id,
        "paid_by": db_user_id,
        "amount": amount,
        "description": desc
    }).execute()
    
    await update.message.reply_text(f"✅ Saved! You logged ${amount:.2f} for {desc}.")
    
    # Announce to Group
    trip_query = supabase.table("trips").select("group_chat_id").eq("id", trip_id).execute()
    if trip_query.data and trip_query.data[0]["group_chat_id"]:
        group_chat_id = trip_query.data[0]["group_chat_id"]
        await context.bot.send_message(
            chat_id=group_chat_id, 
            text=f"💸 **Expense Logged!**\n{update.effective_user.first_name} paid **${amount:.2f}** for {desc}."
        )
    return ConversationHandler.END



async def wiz_lock_cat(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["wiz_cat"] = update.message.text.lower()
    await update.message.reply_text("What is the name or title of this booking? (e.g., 'The Beach House', 'Delta Flight 102')", reply_markup=ReplyKeyboardRemove())
    return LOCK_TITLE

async def wiz_lock_title(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["wiz_title"] = update.message.text.strip()
    await update.message.reply_text(
        "When is it? Please use the exact format:\n`15 June to 18 June 2026`\n\n"
        "*(If it's a one-day event like a flight or dinner, just use the same date twice, e.g., `15 June to 15 June 2026`)*"
    )
    return LOCK_DATES

async def wiz_lock_dates(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_input = update.message.text.strip()
    trip_id = context.user_data["wiz_trip_id"]
    
    # Fetch trip boundaries for the smart parser
    trip_query = supabase.table("trips").select("start_date, end_date").eq("id", trip_id).single().execute()
    t_start = trip_query.data["start_date"]
    t_end = trip_query.data["end_date"]
    
    start_date, end_date = smart_parse_dates(user_input, t_start, t_end)
    
    if not start_date or not end_date:
        await update.message.reply_text("❌ I couldn't find those dates in your trip window.\nTry just the days (e.g., `15-18`), or `Day 1 to Day 3`.")
        return LOCK_DATES

    # Store dates and move to Cost Type
    context.user_data["wiz_start"] = start_date
    context.user_data["wiz_end"] = end_date
    
    reply_markup = ReplyKeyboardMarkup([["Group Cost", "Per Person Cost"], ["Skip Cost"]], one_time_keyboard=True, resize_keyboard=True)
    await update.message.reply_text("💰 How is this priced? Is it a total group cost (like an Airbnb) or a per-person cost (like a flight)?", reply_markup=reply_markup)
    return LOCK_COST_TYPE

async def wiz_lock_cost_type(update: Update, context: ContextTypes.DEFAULT_TYPE):
    choice = update.message.text
    if choice == "Skip Cost":
        context.user_data["wiz_cost_type"] = "None"
        context.user_data["wiz_cost"] = 0.0
        return await finalize_lock(update, context) # Jump straight to saving
        
    context.user_data["wiz_cost_type"] = "Group" if "Group" in choice else "Per Person"
    await update.message.reply_text("What is the estimated amount in dollars? (e.g., 1200 or 350.50)", reply_markup=ReplyKeyboardRemove())
    return LOCK_COST

async def wiz_lock_cost(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        cost = float(update.message.text.replace('$', '').strip())
    except ValueError:
        await update.message.reply_text("❌ Please enter a valid number (e.g., 1200).")
        return LOCK_COST
        
    context.user_data["wiz_cost"] = cost
    return await finalize_lock(update, context)

async def finalize_lock(update: Update, context: ContextTypes.DEFAULT_TYPE):
    trip_id = context.user_data["wiz_trip_id"]
    cat = context.user_data["wiz_cat"]
    title = context.user_data["wiz_title"]
    start_date = context.user_data["wiz_start"]
    end_date = context.user_data["wiz_end"]
    cost_type = context.user_data["wiz_cost_type"]
    cost = context.user_data["wiz_cost"]
    user_id = update.effective_user.id
    
    user_query = supabase.table("users").select("id").eq("telegram_id", user_id).single().execute()
    db_user_id = user_query.data["id"]
    
    # Save to Master Itinerary
    supabase.table("master_itinerary").insert({
        "trip_id": trip_id,
        "category": cat,
        "title": title,
        "start_date": start_date.isoformat(),
        "end_date": end_date.isoformat(),
        "cost_type": cost_type,
        "estimated_cost": cost,
        "locked_by": db_user_id
    }).execute()
    
    await update.message.reply_text("✅ Locked in! The budget and itinerary have been updated.")
    
    # Announce to Group
    group_query = supabase.table("trips").select("group_chat_id").eq("id", trip_id).execute()
    if group_query.data and group_query.data[0]["group_chat_id"]:
        group_chat_id = group_query.data[0]["group_chat_id"]
        
        cost_str = f" \n💰 Est. Cost: ${cost:,.2f} ({cost_type})" if cost > 0 else ""
        date_str = start_date.strftime('%b %d') if start_date == end_date else f"{start_date.strftime('%b %d')} to {end_date.strftime('%b %d')}"
        
        announcement = f"🔒 **Itinerary Update!**\n{update.effective_user.first_name} just locked in **{title}** ({cat.capitalize()}) for {date_str}!{cost_str}"
        
        # THE MILESTONE CHECK: Is this the first locked item?
        itin_query = supabase.table("master_itinerary").select("id").eq("trip_id", trip_id).execute()
        if len(itin_query.data) == 1:
            announcement += (
                "\n\n🎓 **Pro Tip:** We have officially locked in our first plan! "
                "From now on, anyone can type `/itinerary` to see the master timeline, "
                "or `/budget` to see our running cost estimates."
            )
            
        await context.bot.send_message(chat_id=group_chat_id, text=announcement)
    return ConversationHandler.END


async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    help_text = """
🧳 **TripSync Bot - Command Menu** 🧳

**🚀 Setup & RSVPs**
`/new_trip` - Start a new trip (PM only)
`/start` - Join a trip (Group only)
`/roster` - See who is coming
`/change_rsvp` - Update your status

**🗳️ Voting & Itinerary**
`/add_option <category> - <Name> [- <Dates>]` - Suggest an idea
`/vote <category> [- <Dates>]` - Start a poll
`/lock_master <category> - <Title> - <Dates>` - Lock in a winner
`/itinerary` - View the official schedule
`/check_gaps` - Find missing accommodation nights

**💰 Shared Ledger**
`/paid <amount> - <description>` - Log an expense
`/ledger` - View all expenses
`/settle` - Calculate who owes who

**🛠️ Admin/Cleanup**
`/delete_option <category> - <Name>` - Remove a typo'd suggestion
`/remove_itinerary <category> - <Title>` - Cancel a locked booking
    """
    await update.message.reply_text(help_text)

# --- MAIN ---
def main():
    app = Application.builder().token(os.getenv("TELEGRAM_TOKEN")).build()

    # Add the Conversation Handler
    conv_handler = ConversationHandler(
        entry_points=[CommandHandler("new_trip", new_trip)],
        states={
            TITLE: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_title)],
            DESTINATION: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_destination)],
            DATES: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_dates)],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )

   # The Master PM Wizard Handler
    pm_wizard_handler = ConversationHandler(
        entry_points=[CommandHandler("start", wizard_router)],
        states={
            ADD_OPT_CAT: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_addopt_cat)],
            ADD_OPT_NAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_addopt_name)],
            ADD_OPT_DATES: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_addopt_dates)],
            # Paid States
            PAID_AMOUNT: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_paid_amount)],
            PAID_DESC: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_paid_desc)],
            # Lock States
            LOCK_CAT: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_lock_cat)],
            LOCK_TITLE: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_lock_title)],
            LOCK_DATES: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_lock_dates)],
            # Lock Cost States
            LOCK_COST_TYPE: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_lock_cost_type)],
            LOCK_COST: [MessageHandler(filters.TEXT & ~filters.COMMAND, wiz_lock_cost)],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )
    
    app.add_handler(pm_wizard_handler)
    app.add_handler(CommandHandler("roster", roster))
    app.add_handler(CommandHandler("change_rsvp", change_rsvp))
    app.add_handler(CommandHandler("add_option", add_option))
    app.add_handler(CommandHandler("vote", vote))
    app.add_handler(CommandHandler("lock_master", lock_master))
    app.add_handler(CommandHandler("check_gaps", check_gaps))
    app.add_handler(CommandHandler("paid", paid))
    app.add_handler(CommandHandler("ledger", ledger))
    app.add_handler(CommandHandler("settle", settle))
    app.add_handler(CommandHandler("budget", budget))
    app.add_handler(CommandHandler("itinerary", itinerary))
    app.add_handler(CommandHandler("delete_option", delete_option))
    app.add_handler(CommandHandler("remove_itinerary", remove_itinerary))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(conv_handler)
    app.add_handler(CallbackQueryHandler(handle_rsvp, pattern="^rsvp_"))
    

    print("Trip Planner is online...")
    app.run_polling()

if __name__ == "__main__":
    main()